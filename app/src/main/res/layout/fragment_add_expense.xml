<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/add_expense_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sw_background"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/add_expense_app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/sw_background"
        app:liftOnScroll="true"
        app:liftOnScrollTargetViewId="@id/add_expense_scroll_view">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/add_expense_header"
            android:layout_width="match_parent"
            android:layout_height="@dimen/sw_header_height"
            android:background="@color/sw_background"
            android:paddingStart="@dimen/sw_space_12"
            android:paddingEnd="@dimen/sw_space_16">

            <ImageButton
                android:id="@+id/btn_add_expense_back"
                android:layout_width="@dimen/sw_touch_target"
                android:layout_height="@dimen/sw_touch_target"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/action_back"
                android:padding="@dimen/sw_space_10"
                android:src="@drawable/ic_arrow_back"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/sw_text_primary" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_add_expense_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/sw_space_8"
                android:fontFamily="sans-serif-medium"
                android:text="@string/add_expense_title"
                android:textColor="@color/sw_text_primary"
                android:textSize="@dimen/sw_text_size_24"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/btn_add_expense_back"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/add_expense_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/add_expense_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/sw_space_16"
            android:paddingEnd="@dimen/sw_space_16">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_add_expense_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/add_expense_subtitle"
                android:textColor="@color/sw_text_secondary"
                android:textSize="@dimen/sw_text_size_15"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Expense title -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/expense_title_card"
                android:layout_width="0dp"
                android:layout_height="@dimen/sw_add_expense_field_height"
                android:layout_marginStart="@dimen/sw_space_2"
                android:layout_marginTop="@dimen/sw_space_20"
                android:layout_marginEnd="@dimen/sw_space_2"
                app:cardBackgroundColor="@color/sw_surface"
                app:cardCornerRadius="@dimen/sw_corner_radius_18"
                app:cardElevation="@dimen/sw_card_elevation"
                app:cardUseCompatPadding="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_add_expense_subtitle"
                app:strokeColor="@color/sw_outline_soft"
                app:strokeWidth="@dimen/sw_stroke_width">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="@dimen/sw_space_16"
                    android:paddingEnd="@dimen/sw_space_16">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/expense_title_icon_container"
                        android:layout_width="@dimen/sw_icon_container_size_48"
                        android:layout_height="@dimen/sw_icon_container_size_48"
                        app:cardBackgroundColor="@color/sw_surface_primary"
                        app:cardCornerRadius="@dimen/sw_corner_radius_14"
                        app:cardElevation="0dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/img_expense_title"
                            android:layout_width="@dimen/sw_icon_size_24"
                            android:layout_height="@dimen/sw_icon_size_24"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_receipt"
                            app:tint="@color/sw_primary" />

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tv_expense_title_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/sw_space_14"
                        android:layout_marginTop="@dimen/sw_space_22"
                        android:text="@string/expense_title_label"
                        android:textColor="@color/sw_text_secondary"
                        android:textSize="@dimen/sw_text_size_14"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/expense_title_icon_container"
                        app:layout_constraintTop_toTopOf="parent" />

                    <EditText
                        android:id="@+id/et_expense_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/sw_space_14"
                        android:background="@null"
                        android:hint="@string/expense_title_hint"
                        android:inputType="textCapSentences"
                        android:maxLength="40"
                        android:maxLines="1"
                        android:minHeight="@dimen/sw_touch_target"
                        android:padding="0dp"
                        android:singleLine="true"
                        android:textColor="@color/sw_text_primary"
                        android:textColorHint="@color/sw_text_hint"
                        android:textSize="@dimen/sw_text_size_17"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/expense_title_icon_container"
                        app:layout_constraintTop_toBottomOf="@id/tv_expense_title_label" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Amount -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/expense_amount_container"
                android:layout_width="0dp"
                android:layout_height="@dimen/sw_add_expense_amount_height"
                android:layout_marginTop="@dimen/sw_space_16"
                android:background="@drawable/bg_primary_income_input"
                android:paddingStart="@dimen/sw_space_20"
                android:paddingTop="@dimen/sw_space_18"
                android:paddingEnd="@dimen/sw_space_20"
                android:paddingBottom="@dimen/sw_space_16"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/expense_title_card">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_expense_amount_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/amount_label"
                    android:textColor="@color/sw_text_secondary"
                    android:textSize="@dimen/sw_text_size_14"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_expense_currency_symbol"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sw_space_16"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/default_currency_symbol"
                    android:textColor="@color/sw_text_primary"
                    android:textSize="@dimen/sw_text_size_42"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_expense_amount_label" />

                <EditText
                    android:id="@+id/et_expense_amount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/sw_space_12"
                    android:layout_marginTop="@dimen/sw_space_16"
                    android:background="@null"
                    android:fontFamily="sans-serif-medium"
                    android:hint="@string/input_zero"
                    android:inputType="numberDecimal"
                    android:maxLength="9"
                    android:maxLines="1"
                    android:padding="0dp"
                    android:singleLine="true"
                    android:textColor="@color/sw_text_primary"
                    android:textColorHint="@color/sw_text_hint"
                    android:textSize="@dimen/sw_text_size_42"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/tv_expense_currency_symbol"
                    app:layout_constraintTop_toBottomOf="@id/tv_expense_amount_label" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Category -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/category_selector_card"
                android:layout_width="0dp"
                android:layout_height="@dimen/sw_add_expense_field_height"
                android:layout_marginStart="@dimen/sw_space_2"
                android:layout_marginTop="@dimen/sw_space_16"
                android:layout_marginEnd="@dimen/sw_space_2"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/sw_surface"
                app:cardCornerRadius="@dimen/sw_corner_radius_18"
                app:cardElevation="@dimen/sw_card_elevation"
                app:cardUseCompatPadding="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/expense_amount_container"
                app:rippleColor="@color/sw_primary_ripple"
                app:strokeColor="@color/sw_outline_soft"
                app:strokeWidth="@dimen/sw_stroke_width">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="@dimen/sw_space_16"
                    android:paddingEnd="@dimen/sw_space_16">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/category_icon_container"
                        android:layout_width="@dimen/sw_icon_container_size_48"
                        android:layout_height="@dimen/sw_icon_container_size_48"
                        app:cardBackgroundColor="@color/sw_surface_primary"
                        app:cardCornerRadius="@dimen/sw_corner_radius_14"
                        app:cardElevation="0dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:id="@+id/img_category_icon"
                            android:layout_width="@dimen/sw_icon_size_24"
                            android:layout_height="@dimen/sw_icon_size_24"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_category"
                            app:tint="@color/sw_primary" />

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tv_category_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/sw_space_14"
                        android:text="@string/category_label"
                        android:textColor="@color/sw_text_secondary"
                        android:textSize="@dimen/sw_text_size_14"
                        app:layout_constraintEnd_toStartOf="@id/img_category_arrow"
                        app:layout_constraintStart_toEndOf="@id/category_icon_container"
                        app:layout_constraintTop_toTopOf="@id/category_icon_container" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tv_selected_category"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/sw_space_14"
                        android:layout_marginTop="@dimen/sw_space_4"
                        android:text="@string/select_category"
                        android:textColor="@color/sw_text_primary"
                        android:textSize="@dimen/sw_text_size_17"
                        app:layout_constraintEnd_toStartOf="@id/img_category_arrow"
                        app:layout_constraintStart_toEndOf="@id/category_icon_container"
                        app:layout_constraintTop_toBottomOf="@id/tv_category_label" />

                    <ImageView
                        android:id="@+id/img_category_arrow"
                        android:layout_width="@dimen/sw_icon_size_22"
                        android:layout_height="@dimen/sw_icon_size_22"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_arrow_drop_down"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/sw_text_secondary" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Date -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/date_selector_card"
                android:layout_width="0dp"
                android:layout_height="@dimen/sw_add_expense_field_height"
                android:layout_marginStart="@dimen/sw_space_2"
                android:layout_marginTop="@dimen/sw_space_16"
                android:layout_marginEnd="@dimen/sw_space_2"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/sw_surface"
                app:cardCornerRadius="@dimen/sw_corner_radius_18"
                app:cardElevation="@dimen/sw_card_elevation"
                app:cardUseCompatPadding="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/category_selector_card"
                app:rippleColor="@color/sw_primary_ripple"
                app:strokeColor="@color/sw_outline_soft"
                app:strokeWidth="@dimen/sw_stroke_width">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="@dimen/sw_space_16"
                    android:paddingEnd="@dimen/sw_space_16">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/date_icon_container"
                        android:layout_width="@dimen/sw_icon_container_size_48"
                        android:layout_height="@dimen/sw_icon_container_size_48"
                        app:cardBackgroundColor="@color/sw_surface_primary"
                        app:cardCornerRadius="@dimen/sw_corner_radius_14"
                        app:cardElevation="0dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:id="@+id/img_date_icon"
                            android:layout_width="@dimen/sw_icon_size_24"
                            android:layout_height="@dimen/sw_icon_size_24"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_calendar_month"
                            app:tint="@color/sw_primary" />

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tv_date_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/sw_space_14"
                        android:text="@string/date_label"
                        android:textColor="@color/sw_text_secondary"
                        android:textSize="@dimen/sw_text_size_14"
                        app:layout_constraintEnd_toStartOf="@id/img_date_arrow"
                        app:layout_constraintStart_toEndOf="@id/date_icon_container"
                        app:layout_constraintTop_toTopOf="@id/date_icon_container" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tv_selected_date"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/sw_space_14"
                        android:layout_marginTop="@dimen/sw_space_4"
                        android:text="@string/select_date"
                        android:textColor="@color/sw_text_primary"
                        android:textSize="@dimen/sw_text_size_17"
                        app:layout_constraintEnd_toStartOf="@id/img_date_arrow"
                        app:layout_constraintStart_toEndOf="@id/date_icon_container"
                        app:layout_constraintTop_toBottomOf="@id/tv_date_label" />

                    <ImageView
                        android:id="@+id/img_date_arrow"
                        android:layout_width="@dimen/sw_icon_size_22"
                        android:layout_height="@dimen/sw_icon_size_22"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_arrow_forward"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/sw_text_secondary" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Note -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/note_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/sw_space_2"
                android:layout_marginTop="@dimen/sw_space_16"
                android:layout_marginEnd="@dimen/sw_space_2"
                app:cardBackgroundColor="@color/sw_surface"
                app:cardCornerRadius="@dimen/sw_corner_radius_18"
                app:cardElevation="@dimen/sw_card_elevation"
                app:cardUseCompatPadding="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/date_selector_card"
                app:strokeColor="@color/sw_outline_soft"
                app:strokeWidth="@dimen/sw_stroke_width">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="@dimen/sw_space_16"
                    android:paddingTop="@dimen/sw_space_16"
                    android:paddingEnd="@dimen/sw_space_16"
                    android:paddingBottom="@dimen/sw_space_16">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/note_icon_container"
                        android:layout_width="@dimen/sw_icon_container_size_48"
                        android:layout_height="@dimen/sw_icon_container_size_48"
                        app:cardBackgroundColor="@color/sw_surface_primary"
                        app:cardCornerRadius="@dimen/sw_corner_radius_14"
                        app:cardElevation="0dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:id="@+id/img_note_icon"
                            android:layout_width="@dimen/sw_icon_size_24"
                            android:layout_height="@dimen/sw_icon_size_24"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_note"
                            app:tint="@color/sw_primary" />

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tv_note_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/sw_space_14"
                        android:text="@string/note_optional_label"
                        android:textColor="@color/sw_text_secondary"
                        android:textSize="@dimen/sw_text_size_14"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/note_icon_container"
                        app:layout_constraintTop_toTopOf="@id/note_icon_container" />

                    <EditText
                        android:id="@+id/et_expense_note"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/sw_space_14"
                        android:layout_marginTop="@dimen/sw_space_4"
                        android:background="@null"
                        android:gravity="top|start"
                        android:hint="@string/note_hint"
                        android:inputType="textCapSentences|textMultiLine"
                        android:maxLength="150"
                        android:maxLines="4"
                        android:minLines="3"
                        android:overScrollMode="never"
                        android:padding="0dp"
                        android:scrollbars="vertical"
                        android:textColor="@color/sw_text_primary"
                        android:textColorHint="@color/sw_text_hint"
                        android:textSize="@dimen/sw_text_size_16"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/note_icon_container"
                        app:layout_constraintTop_toBottomOf="@id/tv_note_label" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_expense"
                android:layout_width="0dp"
                android:layout_height="@dimen/sw_button_height_large"
                android:layout_marginStart="@dimen/sw_space_2"
                android:layout_marginTop="@dimen/sw_space_24"
                android:layout_marginEnd="@dimen/sw_space_2"
                android:fontFamily="sans-serif-medium"
                android:text="@string/save_expense"
                android:textAllCaps="false"
                android:textColor="@color/sw_on_primary"
                android:textSize="@dimen/sw_text_size_16"
                app:backgroundTint="@color/sw_primary_dark"
                app:cornerRadius="@dimen/sw_corner_radius_16"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/note_card" />

            <Space
                android:id="@+id/add_expense_bottom_space"
                android:layout_width="0dp"
                android:layout_height="@dimen/sw_space_16"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btn_save_expense" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>