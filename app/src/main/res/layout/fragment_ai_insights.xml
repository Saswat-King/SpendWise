<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ai_insights_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/ai_insights_app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/sw_background"
        app:liftOnScroll="true"
        app:liftOnScrollTargetViewId="@id/ai_insights_scroll_view">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/ai_insights_header"
            android:layout_width="match_parent"
            android:layout_height="@dimen/sw_header_height"
            android:background="@color/sw_background"
            android:paddingStart="@dimen/sw_space_16"
            android:paddingEnd="@dimen/sw_space_16">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_ai_insights_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="@string/ai_insights_title"
                android:textColor="@color/sw_text_primary"
                android:textSize="@dimen/sw_text_size_28"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/ai_insights_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/ai_insights_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/sw_space_16"
            android:paddingEnd="@dimen/sw_space_16">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_ai_insights_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/ai_insights_subtitle"
                android:textColor="@color/sw_text_secondary"
                android:textSize="@dimen/sw_text_size_15"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/financial_health_score_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/sw_space_2"
                android:layout_marginTop="@dimen/sw_space_16"
                android:layout_marginEnd="@dimen/sw_space_2"
                app:cardBackgroundColor="@color/sw_surface"
                app:cardCornerRadius="@dimen/sw_corner_radius_24"
                app:cardElevation="@dimen/sw_card_elevation"
                app:cardUseCompatPadding="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_ai_insights_subtitle"
                app:strokeColor="@color/sw_outline_soft"
                app:strokeWidth="@dimen/sw_stroke_width">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="@dimen/sw_space_20"
                    android:paddingTop="@dimen/sw_space_20"
                    android:paddingEnd="@dimen/sw_space_20"
                    android:paddingBottom="@dimen/sw_space_20">

                    <FrameLayout
                        android:id="@+id/health_score_progress_container"
                        android:layout_width="@dimen/sw_health_score_container_size"
                        android:layout_height="@dimen/sw_health_score_container_size"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/health_score_progress"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:indeterminate="false"
                            android:progress="82"
                            app:indicatorColor="@color/sw_primary"
                            app:indicatorSize="@dimen/sw_health_score_indicator_size"
                            app:indicatorTrackGapSize="0dp"
                            app:trackColor="@color/sw_surface_primary"
                            app:trackThickness="@dimen/sw_health_score_track_thickness" />

                        <ImageView
                            android:id="@+id/img_health_score_icon"
                            android:layout_width="@dimen/sw_health_score_icon_size"
                            android:layout_height="@dimen/sw_health_score_icon_size"
                            android:layout_gravity="center"
                            android:contentDescription="@string/content_description_financial_health_score"
                            android:src="@drawable/ic_health_shield" />

                    </FrameLayout>

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tv_financial_health_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/sw_space_18"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/financial_health_score_title"
                        android:textColor="@color/sw_text_primary"
                        android:textSize="@dimen/sw_text_size_18"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/health_score_progress_container"
                        app:layout_constraintTop_toTopOf="@id/health_score_progress_container" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tv_health_score_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sw_space_8"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/financial_health_score_preview"
                        android:textColor="@color/sw_primary"
                        android:textSize="@dimen/sw_text_size_28"
                        app:layout_constraintStart_toStartOf="@id/tv_financial_health_title"
                        app:layout_constraintTop_toBottomOf="@id/tv_financial_health_title" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tv_health_score_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/sw_space_10"
                        android:fontFamily="sans-serif-medium"
                        android:paddingStart="@dimen/sw_space_10"
                        android:paddingTop="@dimen/sw_space_4"
                        android:paddingEnd="@dimen/sw_space_10"
                        android:paddingBottom="@dimen/sw_space_4"
                        android:text="@string/financial_health_status_good"
                        android:textColor="@color/sw_primary"
                        android:textSize="@dimen/sw_text_size_12"
                        app:layout_constraintBaseline_toBaselineOf="@id/tv_health_score_value"
                        app:layout_constraintStart_toEndOf="@id/tv_health_score_value" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tv_health_score_message"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sw_space_10"
                        android:text="@string/financial_health_message"
                        android:textColor="@color/sw_text_secondary"
                        android:textSize="@dimen/sw_text_size_14"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="@id/tv_financial_health_title"
                        app:layout_constraintTop_toBottomOf="@id/tv_health_score_value" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>


            <com.google.android.material.card.MaterialCardView
                android:id="@+id/key_insights_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/sw_space_2"
                android:layout_marginTop="@dimen/sw_space_16"
                android:layout_marginEnd="@dimen/sw_space_2"
                app:cardBackgroundColor="@color/sw_surface"
                app:cardCornerRadius="@dimen/sw_corner_radius_24"
                app:cardElevation="@dimen/sw_card_elevation"
                app:cardUseCompatPadding="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/financial_health_score_card"
                app:strokeColor="@color/sw_outline_soft"
                app:strokeWidth="@dimen/sw_stroke_width">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="@dimen/sw_space_18"
                    android:paddingTop="@dimen/sw_space_18"
                    android:paddingEnd="@dimen/sw_space_18"
                    android:paddingBottom="@dimen/sw_space_18">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tv_key_insights_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/key_insights_title"
                        android:textColor="@color/sw_text_primary"
                        android:textSize="@dimen/sw_text_size_18"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_key_insights"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sw_space_16"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_key_insights_title" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>


            <com.google.android.material.card.MaterialCardView
                android:id="@+id/budget_warnings_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/sw_space_2"
                android:layout_marginTop="@dimen/sw_space_16"
                android:layout_marginEnd="@dimen/sw_space_2"
                app:cardBackgroundColor="@color/sw_surface"
                app:cardCornerRadius="@dimen/sw_corner_radius_24"
                app:cardElevation="@dimen/sw_card_elevation"
                app:cardUseCompatPadding="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/key_insights_card"
                app:strokeColor="@color/sw_outline_soft"
                app:strokeWidth="@dimen/sw_stroke_width">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="@dimen/sw_space_18"
                    android:paddingTop="@dimen/sw_space_18"
                    android:paddingEnd="@dimen/sw_space_18"
                    android:paddingBottom="@dimen/sw_space_18">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tv_budget_warnings_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/budget_warnings_title"
                        android:textColor="@color/sw_text_primary"
                        android:textSize="@dimen/sw_text_size_18"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_budget_warnings"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sw_space_16"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_budget_warnings_title" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_view_all_budgets"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/sw_button_height"
                        android:layout_marginTop="@dimen/sw_space_16"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center_vertical|start"
                        android:paddingStart="@dimen/sw_space_16"
                        android:paddingEnd="@dimen/sw_space_14"
                        android:text="@string/view_all_budgets"
                        android:textAllCaps="false"
                        android:textColor="@color/sw_primary"
                        android:textSize="@dimen/sw_text_size_14"
                        app:backgroundTint="@color/sw_surface_primary"
                        app:cornerRadius="@dimen/sw_corner_radius_14"
                        app:icon="@drawable/ic_arrow_forward"
                        app:iconGravity="end"
                        app:iconPadding="0dp"
                        app:iconSize="@dimen/sw_icon_size_18"
                        app:iconTint="@color/sw_primary"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/rv_budget_warnings" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <Space
                android:id="@+id/ai_insights_bottom_space"
                android:layout_width="0dp"
                android:layout_height="@dimen/sw_space_12"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/budget_warnings_card" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>