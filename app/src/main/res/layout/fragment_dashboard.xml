<?xml version="1.0" encoding="utf-8"?>

<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <androidx.core.widget.NestedScrollView
        android:id="@+id/dashboard_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/dashboard_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp">


            <ImageButton
                android:id="@+id/btn_menu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/open_navigation_menu"
                android:padding="12dp"
                android:src="@drawable/ic_menu"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="#101828" />


            <ImageView
                android:id="@+id/img_logo"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="10dp"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:src="@drawable/spendwise_logo"
                app:layout_constraintBottom_toBottomOf="@id/btn_menu"
                app:layout_constraintStart_toEndOf="@id/btn_menu"
                app:layout_constraintTop_toTopOf="@id/btn_menu" />


            <TextView
                android:id="@+id/tv_app_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/app_name"
                android:textColor="#101828"
                android:textSize="22sp"
                app:layout_constraintBottom_toBottomOf="@id/img_logo"
                app:layout_constraintStart_toEndOf="@id/img_logo"
                app:layout_constraintTop_toTopOf="@id/img_logo" />

            <ImageButton
                android:id="@+id/btn_notification"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/notifications"
                android:padding="12dp"
                android:src="@drawable/ic_notifications"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="#101828" />


            <TextView
                android:id="@+id/tv_greeting"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="sans-serif-medium"
                android:text="Good morning, Ashik! 👋"
                android:textColor="#101828"
                android:textSize="24sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btn_menu" />


            <TextView
                android:id="@+id/tv_overview"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Here's your financial overview"
                android:textColor="#667085"
                android:textSize="15sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_greeting" />


            <com.google.android.material.card.MaterialCardView
                android:id="@+id/balance_card"
                android:layout_width="0dp"
                android:layout_height="230dp"
                android:layout_marginStart="2dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="2dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/sw_card_bg"
                app:cardUseCompatPadding="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_overview"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="20dp">

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/vertical_top_guideline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="visible"
                        app:layout_constraintGuide_begin="165dp" />


                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/horizontal_divider_guideline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:visibility="visible"
                        app:layout_constraintGuide_percent="0.64" />


                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/vertical_bottom_guideline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="visible"
                        app:layout_constraintGuide_percent="0.50" />


                    <TextView
                        android:id="@+id/tv_available_balance_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Available balance"
                        android:textColor="#D9FFFFFF"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toStartOf="@id/vertical_top_guideline"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />


                    <TextView
                        android:id="@+id/tv_available_balance"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:ellipsize="end"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:text="$0.00"
                        android:textColor="@android:color/white"
                        android:textSize="28sp"
                        app:layout_constraintEnd_toEndOf="@id/tv_available_balance_label"
                        app:layout_constraintStart_toStartOf="@+id/tv_available_balance_label"
                        app:layout_constraintTop_toBottomOf="@id/tv_available_balance_label" />


                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_month"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="11dp"
                        android:paddingEnd="7dp"
                        android:text="This month"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        app:cornerRadius="10dp"
                        app:icon="@drawable/ic_arrow_drop_down"
                        app:iconGravity="textEnd"
                        app:iconPadding="3dp"
                        app:iconSize="18dp"
                        app:iconTint="@android:color/white"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:strokeColor="#66FFFFFF"
                        app:strokeWidth="1dp" />


                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/balance_chart"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"
                        android:background="@android:color/transparent"
                        app:layout_constraintBottom_toTopOf="@id/divider_balance"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/vertical_top_guideline"
                        app:layout_constraintTop_toBottomOf="@id/btn_month" />


                    <View
                        android:id="@+id/divider_balance"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:background="#33FFFFFF"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@id/horizontal_divider_guideline" />


                    <TextView
                        android:id="@+id/tv_income_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="start"
                        android:text="Income"
                        android:textColor="#D9FFFFFF"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toStartOf="@id/vertical_bottom_guideline"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/divider_balance" />


                    <TextView
                        android:id="@+id/tv_income_amount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:ellipsize="end"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:text="+$0.00"
                        android:textColor="@android:color/white"
                        android:textSize="17sp"
                        app:layout_constraintEnd_toEndOf="@+id/tv_income_label"
                        app:layout_constraintStart_toStartOf="@+id/tv_income_label"
                        app:layout_constraintTop_toBottomOf="@id/tv_income_label" />


                    <View
                        android:id="@+id/divider_income_expense"
                        android:layout_width="1dp"
                        android:layout_height="0dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="2dp"
                        android:background="#33FFFFFF"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="@id/vertical_bottom_guideline"
                        app:layout_constraintTop_toBottomOf="@id/divider_balance" />

                    <TextView
                        android:id="@+id/tv_expense_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="18dp"
                        android:layout_marginTop="12dp"
                        android:text="Expense"
                        android:textColor="#D9FFFFFF"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/vertical_bottom_guideline"
                        app:layout_constraintTop_toBottomOf="@id/divider_balance" />


                    <TextView
                        android:id="@+id/tv_expense_amount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:ellipsize="end"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:text="-$0.00"
                        android:textColor="@android:color/white"
                        android:textSize="17sp"
                        app:layout_constraintEnd_toEndOf="@+id/tv_expense_label"
                        app:layout_constraintStart_toStartOf="@+id/tv_expense_label"
                        app:layout_constraintTop_toBottomOf="@id/tv_expense_label" />


                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>


            <com.google.android.material.card.MaterialCardView
                android:id="@+id/budget_overview_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="2dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:cardUseCompatPadding="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/balance_card"
                app:strokeColor="#EEF2F6"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="18dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="18dp">

                    <TextView
                        android:id="@+id/tv_budget_overview_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Budget Overview"
                        android:textColor="#101828"
                        android:textSize="17sp"
                        app:layout_constraintEnd_toStartOf="@id/tv_budget_view_all"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_budget_view_all"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="View all"
                        android:textColor="#0F7A5A"
                        android:textSize="13sp"
                        app:layout_constraintBaseline_toBaselineOf="@id/tv_budget_overview_title"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/budget_progress_container"
                        android:layout_width="176dp"
                        android:layout_height="176dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_budget_overview_title">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/budget_circular_progress"
                            android:layout_width="152dp"
                            android:layout_height="152dp"
                            android:indeterminate="false"
                            android:progress="65"
                            app:indicatorColor="#197A5A"
                            app:indicatorDirectionCircular="clockwise"
                            app:indicatorInset="0dp"
                            app:indicatorSize="152dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:trackColor="#E9ECEF"
                            app:trackCornerRadius="7dp"
                            app:trackThickness="13dp" />

                        <LinearLayout
                            android:id="@+id/budget_progress_text_group"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <TextView
                                android:id="@+id/tv_budget_percent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="65%"
                                android:textColor="#101828"
                                android:textSize="28sp" />

                            <TextView
                                android:id="@+id/tv_budget_used_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="1dp"
                                android:text="of budget used"
                                android:textColor="#667085"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tv_budget_used_amount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:fontFamily="sans-serif-medium"
                                android:text="$1,625.00"
                                android:textColor="#101828"
                                android:textSize="16sp" />

                            <TextView
                                android:id="@+id/tv_budget_total_amount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="1dp"
                                android:text="of $2,500.00"
                                android:textColor="#667085"
                                android:textSize="10sp" />

                        </LinearLayout>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_budget_categories_preview"
                        android:layout_width="0dp"
                        android:layout_height="156dp"
                        android:layout_marginStart="16dp"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        app:layout_constraintBottom_toBottomOf="@id/budget_progress_container"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/budget_progress_container"
                        app:layout_constraintTop_toTopOf="@id/budget_progress_container" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>


            <com.google.android.material.card.MaterialCardView
                android:id="@+id/recent_expenses_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="2dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:cardUseCompatPadding="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/budget_overview_card"
                app:strokeColor="#EEF2F6"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="18dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="18dp">

                    <TextView
                        android:id="@+id/tv_recent_expenses_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Recent Expenses"
                        android:textColor="#101828"
                        android:textSize="17sp"
                        app:layout_constraintEnd_toStartOf="@id/tv_recent_expenses_view_all"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_recent_expenses_view_all"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:minHeight="48dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="0dp"
                        android:text="View all"
                        android:textColor="#0F7A5A"
                        android:textSize="13sp"
                        app:layout_constraintBaseline_toBaselineOf="@id/tv_recent_expenses_title"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_recent_expenses_preview"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:minHeight="176dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_recent_expenses_title" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>


            <com.google.android.material.card.MaterialCardView
                android:id="@+id/ai_insight_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="2dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:cardUseCompatPadding="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/recent_expenses_card"
                app:strokeColor="#EEF2F6"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="18dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="18dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/ai_icon_container"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        app:cardBackgroundColor="#EAF7F2"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardUseCompatPadding="false"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/img_ai_icon"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:contentDescription="AI insight"
                            android:src="@drawable/ic_ai_sparkle" />

                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tv_ai_insight_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="AI Insight"
                        android:textColor="#101828"
                        android:textSize="17sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ai_icon_container"
                        app:layout_constraintTop_toTopOf="@id/ai_icon_container" />

                    <TextView
                        android:id="@+id/tv_ai_insight_subtitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="3dp"
                        android:text="Smart summary of your spending"
                        android:textColor="#667085"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ai_icon_container"
                        app:layout_constraintTop_toBottomOf="@id/tv_ai_insight_title" />

                    <TextView
                        android:id="@+id/tv_ai_insight_message"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:lineSpacingExtra="2dp"
                        android:text="You spent more on shopping this week than usual. Review your recent expenses to stay within your monthly budget."
                        android:textColor="#475467"
                        android:textSize="14sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/ai_icon_container" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_view_ai_insight"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="16dp"
                        android:fontFamily="sans-serif-medium"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:paddingStart="18dp"
                        android:paddingEnd="14dp"
                        android:text="View insight"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        app:backgroundTint="#0F7A5A"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_arrow_forward"
                        app:iconGravity="textEnd"
                        app:iconPadding="6dp"
                        app:iconSize="17dp"
                        app:iconTint="@android:color/white"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_ai_insight_message" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Continue adding remaining cards/views here.
                 Every next view should constrain its top
                 to the bottom of the previous view. -->

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigation_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
