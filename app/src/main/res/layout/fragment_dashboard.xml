<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dashboard_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/dashboard_app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/sw_background"
        app:elevation="0dp"
        app:liftOnScroll="true"
        app:liftOnScrollTargetViewId="@id/dashboard_scroll_view">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/dashboard_top_header"
            android:layout_width="match_parent"
            android:layout_height="@dimen/sw_dashboard_header_height"
            android:background="@color/sw_background"
            android:paddingStart="@dimen/sw_space_16"
            android:paddingEnd="@dimen/sw_space_16">

            <ImageView
                android:id="@+id/img_logo"
                android:layout_width="@dimen/sw_dashboard_logo_size"
                android:layout_height="@dimen/sw_dashboard_logo_size"
                android:layout_marginTop="@dimen/sw_space_15"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:src="@drawable/spendwise_logo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_app_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/sw_space_7"
                android:fontFamily="sans-serif-medium"
                android:text="@string/app_name"
                android:textColor="@color/sw_text_primary"
                android:textSize="@dimen/sw_text_size_22"
                app:layout_constraintBottom_toBottomOf="@id/img_logo"
                app:layout_constraintStart_toEndOf="@id/img_logo"
                app:layout_constraintTop_toTopOf="@id/img_logo" />

            <ImageButton
                android:id="@+id/btn_notification"
                android:layout_width="@dimen/sw_touch_target"
                android:layout_height="@dimen/sw_touch_target"
                android:layout_marginTop="@dimen/sw_space_8"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/content_description_notifications"
                android:padding="@dimen/sw_space_12"
                android:src="@drawable/ic_notifications"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/sw_text_primary" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/dashboard_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/dashboard_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/sw_space_16"
            android:paddingEnd="@dimen/sw_space_16">

            <TextView
                android:id="@+id/tv_greeting"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sw_space_24"
                android:fontFamily="sans-serif-medium"
                android:text="@string/dashboard_greeting_preview"
                android:textColor="@color/sw_text_primary"
                android:textSize="@dimen/sw_text_size_24"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_overview"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sw_space_6"
                android:text="@string/dashboard_overview_subtitle"
                android:textColor="@color/sw_text_secondary"
                android:textSize="@dimen/sw_text_size_15"
                app:layout_constraintEnd_toEndOf="@id/tv_greeting"
                app:layout_constraintStart_toStartOf="@id/tv_greeting"
                app:layout_constraintTop_toBottomOf="@id/tv_greeting" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/balance_card"
                android:layout_width="0dp"
                android:layout_height="@dimen/sw_dashboard_balance_card_height"
                android:layout_marginStart="@dimen/sw_space_2"
                android:layout_marginTop="@dimen/sw_space_16"
                android:layout_marginEnd="@dimen/sw_space_2"
                app:cardBackgroundColor="@color/sw_primary"
                app:cardCornerRadius="@dimen/sw_corner_radius_20"
                app:cardElevation="@dimen/sw_card_elevation"
                app:cardUseCompatPadding="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_overview"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="@dimen/sw_space_20">

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/vertical_top_guideline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="visible"
                        app:layout_constraintGuide_begin="@dimen/sw_dashboard_chart_guideline" />

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/horizontal_divider_guideline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:visibility="visible"
                        app:layout_constraintGuide_percent="0.64" />

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/vertical_bottom_guideline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="visible"
                        app:layout_constraintGuide_percent="0.50" />

                    <TextView
                        android:id="@+id/tv_available_balance_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/available_balance_label"
                        android:textColor="@color/sw_on_primary_85"
                        android:textSize="@dimen/sw_text_size_14"
                        app:layout_constraintEnd_toStartOf="@id/vertical_top_guideline"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_available_balance"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sw_space_5"
                        android:ellipsize="end"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:text="@string/amount_dollar_zero"
                        android:textColor="@color/sw_on_primary"
                        android:textSize="@dimen/sw_text_size_28"
                        app:layout_constraintEnd_toStartOf="@id/vertical_top_guideline"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_available_balance_label" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_month"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="@dimen/sw_space_11"
                        android:paddingEnd="@dimen/sw_space_7"
                        android:text="@string/dashboard_filter_this_month"
                        android:textAllCaps="false"
                        android:textColor="@color/sw_on_primary"
                        android:textSize="@dimen/sw_text_size_12"
                        app:cornerRadius="@dimen/sw_corner_radius_10"
                        app:icon="@drawable/ic_arrow_drop_down"
                        app:iconGravity="textEnd"
                        app:iconPadding="@dimen/sw_space_3"
                        app:iconSize="@dimen/sw_icon_size_18"
                        app:iconTint="@color/sw_on_primary"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:strokeColor="@color/sw_on_primary_40"
                        app:strokeWidth="@dimen/sw_stroke_width" />

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/balance_chart"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_marginStart="@dimen/sw_space_8"
                        android:layout_marginTop="@dimen/sw_space_4"
                        android:layout_marginBottom="@dimen/sw_space_4"
                        android:background="@android:color/transparent"
                        app:layout_constraintBottom_toTopOf="@id/divider_balance"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/vertical_top_guideline"
                        app:layout_constraintTop_toBottomOf="@id/btn_month" />

                    <View
                        android:id="@+id/divider_balance"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/sw_divider_thickness"
                        android:background="@color/sw_on_primary_20"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@id/horizontal_divider_guideline" />

                    <TextView
                        android:id="@+id/tv_income_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sw_space_12"
                        android:gravity="start"
                        android:text="@string/income_label"
                        android:textColor="@color/sw_on_primary_85"
                        android:textSize="@dimen/sw_text_size_13"
                        app:layout_constraintEnd_toStartOf="@id/vertical_bottom_guideline"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/divider_balance" />

                    <TextView
                        android:id="@+id/tv_income_amount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sw_space_3"
                        android:ellipsize="end"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:text="@string/amount_dollar_income_zero"
                        android:textColor="@color/sw_on_primary"
                        android:textSize="@dimen/sw_text_size_17"
                        app:layout_constraintEnd_toEndOf="@id/tv_income_label"
                        app:layout_constraintStart_toStartOf="@id/tv_income_label"
                        app:layout_constraintTop_toBottomOf="@id/tv_income_label" />

                    <View
                        android:id="@+id/divider_income_expense"
                        android:layout_width="@dimen/sw_divider_thickness"
                        android:layout_height="0dp"
                        android:layout_marginTop="@dimen/sw_space_12"
                        android:layout_marginBottom="@dimen/sw_space_2"
                        android:background="@color/sw_on_primary_20"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="@id/vertical_bottom_guideline"
                        app:layout_constraintTop_toBottomOf="@id/divider_balance" />

                    <TextView
                        android:id="@+id/tv_expense_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/sw_space_18"
                        android:layout_marginTop="@dimen/sw_space_12"
                        android:text="@string/expense_label"
                        android:textColor="@color/sw_on_primary_85"
                        android:textSize="@dimen/sw_text_size_13"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/vertical_bottom_guideline"
                        app:layout_constraintTop_toBottomOf="@id/divider_balance" />

                    <TextView
                        android:id="@+id/tv_expense_amount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sw_space_3"
                        android:ellipsize="end"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:text="@string/amount_dollar_expense_zero"
                        android:textColor="@color/sw_on_primary"
                        android:textSize="@dimen/sw_text_size_17"
                        app:layout_constraintEnd_toEndOf="@id/tv_expense_label"
                        app:layout_constraintStart_toStartOf="@id/tv_expense_label"
                        app:layout_constraintTop_toBottomOf="@id/tv_expense_label" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/budget_overview_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/sw_space_2"
                android:layout_marginTop="@dimen/sw_space_16"
                android:layout_marginEnd="@dimen/sw_space_2"
                app:cardBackgroundColor="@color/sw_surface"
                app:cardCornerRadius="@dimen/sw_corner_radius_18"
                app:cardElevation="@dimen/sw_card_elevation"
                app:cardUseCompatPadding="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/balance_card"
                app:strokeColor="@color/sw_outline_subtle"
                app:strokeWidth="@dimen/sw_stroke_width">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="@dimen/sw_space_18"
                    android:paddingTop="@dimen/sw_space_18"
                    android:paddingEnd="@dimen/sw_space_18"
                    android:paddingBottom="@dimen/sw_space_18">

                    <TextView
                        android:id="@+id/tv_budget_overview_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/budget_overview_title"
                        android:textColor="@color/sw_text_primary"
                        android:textSize="@dimen/sw_text_size_17"
                        app:layout_constraintEnd_toStartOf="@id/tv_budget_view_all"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_budget_view_all"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:minHeight="49dp"
                        android:paddingStart="@dimen/sw_space_8"
                        android:paddingEnd="0dp"
                        android:text="@string/action_view_all"
                        android:textColor="@color/sw_primary_action"
                        android:textSize="@dimen/sw_text_size_13"
                        app:layout_constraintBaseline_toBaselineOf="@id/tv_budget_overview_title"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/budget_progress_container"
                        android:layout_width="@dimen/sw_dashboard_budget_progress_size"
                        android:layout_height="@dimen/sw_dashboard_budget_progress_size"
                        android:layout_marginTop="@dimen/sw_space_12"
                        android:layout_marginBottom="@dimen/sw_space_12"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_budget_overview_title">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/budget_circular_progress"
                            android:layout_width="@dimen/sw_dashboard_budget_indicator_size"
                            android:layout_height="@dimen/sw_dashboard_budget_indicator_size"
                            android:indeterminate="false"
                            android:progress="65"
                            app:indicatorColor="@color/sw_primary_progress"
                            app:indicatorDirectionCircular="clockwise"
                            app:indicatorInset="0dp"
                            app:indicatorSize="@dimen/sw_dashboard_budget_indicator_size"
                            app:indicatorTrackGapSize="0dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:trackColor="@color/sw_progress_track"
                            app:trackCornerRadius="@dimen/sw_corner_radius_7"
                            app:trackStopIndicatorSize="0dp"
                            app:trackThickness="@dimen/sw_dashboard_budget_track_thickness" />

                        <LinearLayout
                            android:id="@+id/budget_progress_text_group"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <TextView
                                android:id="@+id/tv_budget_percent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="@string/budget_used_percent_preview"
                                android:textColor="@color/sw_text_primary"
                                android:textSize="@dimen/sw_text_size_28" />

                            <TextView
                                android:id="@+id/tv_budget_used_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/sw_space_1"
                                android:text="@string/budget_used_label"
                                android:textColor="@color/sw_text_secondary"
                                android:textSize="@dimen/sw_text_size_13" />

                            <TextView
                                android:id="@+id/tv_budget_used_amount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/sw_space_8"
                                android:fontFamily="sans-serif-medium"
                                android:text="@string/budget_spent_preview"
                                android:textColor="@color/sw_text_primary"
                                android:textSize="@dimen/sw_text_size_16" />

                            <TextView
                                android:id="@+id/tv_budget_total_amount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/sw_space_1"
                                android:text="@string/budget_total_preview"
                                android:textColor="@color/sw_text_secondary"
                                android:textSize="@dimen/sw_text_size_10" />

                        </LinearLayout>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_budget_categories_preview"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/sw_dashboard_budget_list_height"
                        android:layout_marginStart="@dimen/sw_space_16"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        app:layout_constraintBottom_toBottomOf="@id/budget_progress_container"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/budget_progress_container"
                        app:layout_constraintTop_toTopOf="@id/budget_progress_container" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/recent_expenses_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/sw_space_2"
                android:layout_marginTop="@dimen/sw_space_16"
                android:layout_marginEnd="@dimen/sw_space_2"
                app:cardBackgroundColor="@color/sw_surface"
                app:cardCornerRadius="@dimen/sw_corner_radius_18"
                app:cardElevation="@dimen/sw_card_elevation"
                app:cardUseCompatPadding="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/budget_overview_card"
                app:strokeColor="@color/sw_outline_subtle"
                app:strokeWidth="@dimen/sw_stroke_width">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="@dimen/sw_space_18"
                    android:paddingTop="@dimen/sw_space_18"
                    android:paddingEnd="@dimen/sw_space_18"
                    android:paddingBottom="@dimen/sw_space_18">

                    <TextView
                        android:id="@+id/tv_recent_expenses_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/recent_expenses_title"
                        android:textColor="@color/sw_text_primary"
                        android:textSize="@dimen/sw_text_size_17"
                        app:layout_constraintEnd_toStartOf="@id/tv_recent_expenses_view_all"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_recent_expenses_view_all"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:minHeight="49dp"
                        android:paddingStart="@dimen/sw_space_8"
                        android:paddingEnd="0dp"
                        android:text="@string/action_view_all"
                        android:textColor="@color/sw_primary_action"
                        android:textSize="@dimen/sw_text_size_13"
                        app:layout_constraintBaseline_toBaselineOf="@id/tv_recent_expenses_title"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_recent_expenses_preview"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sw_space_12"
                        android:layout_marginBottom="@dimen/sw_space_12"
                        android:clipToPadding="false"
                        android:minHeight="@dimen/sw_dashboard_recent_list_min_height"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_recent_expenses_title" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/ai_insight_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/sw_space_2"
                android:layout_marginTop="@dimen/sw_space_16"
                android:layout_marginEnd="@dimen/sw_space_2"
                app:cardBackgroundColor="@color/sw_surface"
                app:cardCornerRadius="@dimen/sw_corner_radius_18"
                app:cardElevation="@dimen/sw_card_elevation"
                app:cardUseCompatPadding="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/recent_expenses_card"
                app:strokeColor="@color/sw_outline_subtle"
                app:strokeWidth="@dimen/sw_stroke_width">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="@dimen/sw_space_18"
                    android:paddingTop="@dimen/sw_space_18"
                    android:paddingEnd="@dimen/sw_space_18"
                    android:paddingBottom="@dimen/sw_space_18">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/ai_icon_container"
                        android:layout_width="@dimen/sw_icon_container_size_42"
                        android:layout_height="@dimen/sw_icon_container_size_42"
                        app:cardBackgroundColor="@color/sw_surface_primary_subtle"
                        app:cardCornerRadius="@dimen/sw_corner_radius_12"
                        app:cardElevation="0dp"
                        app:cardUseCompatPadding="false"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/img_ai_icon"
                            android:layout_width="@dimen/sw_icon_size_22"
                            android:layout_height="@dimen/sw_icon_size_22"
                            android:layout_gravity="center"
                            android:contentDescription="@string/content_description_ai_insight"
                            android:src="@drawable/ic_ai_sparkle" />

                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tv_ai_insight_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/sw_space_12"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/dashboard_ai_insight_title"
                        android:textColor="@color/sw_text_primary"
                        android:textSize="@dimen/sw_text_size_17"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ai_icon_container"
                        app:layout_constraintTop_toTopOf="@id/ai_icon_container" />

                    <TextView
                        android:id="@+id/tv_ai_insight_subtitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sw_space_3"
                        android:text="@string/dashboard_ai_insight_subtitle"
                        android:textColor="@color/sw_text_secondary"
                        android:textSize="@dimen/sw_text_size_13"
                        app:layout_constraintEnd_toEndOf="@id/tv_ai_insight_title"
                        app:layout_constraintStart_toStartOf="@id/tv_ai_insight_title"
                        app:layout_constraintTop_toBottomOf="@id/tv_ai_insight_title" />

                    <TextView
                        android:id="@+id/tv_ai_insight_message"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sw_space_32"
                        android:lineSpacingExtra="@dimen/sw_space_2"
                        android:text="@string/dashboard_ai_insight_message"
                        android:textColor="@color/sw_text_tertiary"
                        android:textSize="@dimen/sw_text_size_14"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_ai_insight_subtitle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_view_ai_insight"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/sw_button_height_small"
                        android:layout_marginTop="@dimen/sw_space_16"
                        android:fontFamily="sans-serif-medium"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="@dimen/sw_space_18"
                        android:paddingEnd="@dimen/sw_space_14"
                        android:text="@string/action_view_insight"
                        android:textAllCaps="false"
                        android:textColor="@color/sw_on_primary"
                        android:textSize="@dimen/sw_text_size_13"
                        app:backgroundTint="@color/sw_primary_action"
                        app:cornerRadius="@dimen/sw_corner_radius_12"
                        app:icon="@drawable/ic_arrow_forward"
                        app:iconGravity="textEnd"
                        app:iconPadding="@dimen/sw_space_6"
                        app:iconSize="@dimen/sw_icon_size_17"
                        app:iconTint="@color/sw_on_primary"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_ai_insight_message" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <Space
                android:id="@+id/dashboard_bottom_space"
                android:layout_width="0dp"
                android:layout_height="@dimen/sw_space_12"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ai_insight_card" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>