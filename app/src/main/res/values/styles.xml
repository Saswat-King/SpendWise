<?xml version="1.0" encoding="utf-8"?>
<resources>

<!--   Bottom Navigation-->


    <!-- Bottom-navigation selected-item indicator -->
    <style name="SpendWiseBottomNavigationIndicator">
        <item name="android:width">56dp</item>
        <item name="android:height">32dp</item>
        <item name="android:color">@color/sw_nav_active_indicator</item>
        <item name="shapeAppearance">
            @style/SpendWiseBottomNavigationIndicatorShape
        </item>
    </style>

    <style name="SpendWiseBottomNavigationIndicatorShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style
        name="BottomNavText"
        parent="TextAppearance.MaterialComponents.Caption">

        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>

    </style>


    <style name="TextAppearance.SpendWise.BudgetCategoryName" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.SpendWise.BudgetPercent" parent="TextAppearance.MaterialComponents.Caption" />

    <style name="Widget.SpendWise.BudgetProgressIndicator" parent="Widget.MaterialComponents.LinearProgressIndicator" />

    <style name="TextAppearance.SpendWise.BudgetAmount" parent="TextAppearance.MaterialComponents.Body2" />

    <style name="TextAppearance.SpendWise.SpendCategory" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.SpendWise.SpendAmount" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.SpendWise.SpendDescription" parent="TextAppearance.MaterialComponents.Body2" />

    <style name="TextAppearance.SpendWise.SpendDate" parent="TextAppearance.MaterialComponents.Caption" />


</resources>
